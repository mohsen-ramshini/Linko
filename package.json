{
  "name": "linko-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Linko Monorepo",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=apps/linko_frontend",
    "dev:backend": "npm run dev --workspace=apps/linko_backend",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.0.0"
  }
}